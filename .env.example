# API Configuration
NOVA_API_URL=https://your-api-domain.com
NOVA_API_KEY=your_api_key_here

# Signing & Constitution
NOVA_SIGNING_SECRET=replace_me
NOVA_CONSTITUTION_VERSION=v1.0

# Epoch & Regime Defaults
NOVA_EPOCH=2461
NOVA_TIMESTAMP_UTC=2026-03-31T14:00:00Z
NOVA_REGIME=Elevated Fragility

# Usage Tracking (optional; defaults to .usage.json)
# NOVA_USAGE_FILE=/path/to/usage.json

# Redis (optional; enables shared state across instances)
# NOVA_REDIS_URL=redis://localhost:6379
